---
import Logo from './Logo.astro';
import { nav } from '../config/site';
const path = Astro.url.pathname;
const isActive = (href: string) => {
  const base = href.split('#')[0];
  if (base === '/') return path === '/';
  return base !== '' && path.startsWith(base);
};
---

<header class="header" data-header>
  <div class="header__inner wrap">
    <a href="/" class="header__brand" aria-label="Rhinelab — home">
      <Logo size={36} />
    </a>

    <button
      class="header__toggle"
      data-nav-toggle
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Toggle navigation menu"
    >
      <span></span><span></span><span></span>
    </button>

    <nav class="header__nav" id="primary-nav" data-nav aria-label="Primary">
      <ul role="list">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="header__link"
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--glass);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--line);
  }
  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .header__nav ul {
    display: flex;
    align-items: center;
    gap: clamp(0.6rem, 1.4vw, 1.6rem);
  }
  .header__link {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 0.9rem;
    color: var(--mist);
    padding: 0.5em 0.1em;
    transition: color var(--dur);
  }
  .header__link:hover {
    color: var(--ink);
  }
  .header__link[aria-current='page'] {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--line-strong);
    text-underline-offset: 4px;
  }

  /* Mobile toggle */
  .header__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    padding: 8px 4px;
    z-index: 110;
  }
  .header__toggle span {
    width: 26px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.3s var(--ease), opacity 0.3s;
  }

  @media (max-width: 880px) {
    .header__toggle {
      display: flex;
    }
    .header__nav {
      position: fixed;
      inset: 0;
      background: var(--abyss);
      display: grid;
      place-items: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s var(--ease);
    }
    .header__nav ul {
      flex-direction: column;
      gap: 0.8rem;
      text-align: center;
    }
    .header__link {
      font-size: 1.4rem;
      font-weight: 500;
      color: var(--foam);
    }
    :global(.header.nav-open) .header__nav {
      opacity: 1;
      pointer-events: auto;
    }
    :global(.header.nav-open) .header__toggle span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    :global(.header.nav-open) .header__toggle span:nth-child(2) {
      opacity: 0;
    }
    :global(.header.nav-open) .header__toggle span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
