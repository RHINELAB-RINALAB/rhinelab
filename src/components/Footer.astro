---
import Logo from './Logo.astro';
import { site, nav, fields } from '../config/site';
const year = new Date().getFullYear();
const socials = Object.entries(site.social).filter(([, v]) => v);
const labelMap: Record<string, string> = {
  github: 'GitHub',
  gitlab: 'GitLab',
  x: 'X',
  linkedin: 'LinkedIn',
  scholar: 'Scholar',
};
---

<footer class="footer">
  <div class="wrap footer__grid">
    <div class="footer__brand">
      <a href="/" aria-label="Rhinelab — home">
        <Logo size={34} subtitle={true} />
      </a>
      <p class="footer__tag">{site.tagline}</p>
      <ul role="list" class="footer__social">
        {
          socials.map(([key, href]) => (
            <li>
              <a class="link-wave" href={href} target="_blank" rel="noopener">
                {labelMap[key] ?? key}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <nav class="footer__col" aria-label="Footer">
      <h2 class="footer__head">Navigate</h2>
      <ul role="list">
        {nav.map((i) => <li><a href={i.href}>{i.label}</a></li>)}
      </ul>
    </nav>

    <div class="footer__col">
      <h2 class="footer__head">Fields</h2>
      <ul role="list">
        {fields.map((f) => <li>{f.label}</li>)}
      </ul>
    </div>

    <div class="footer__col">
      <h2 class="footer__head">Contact</h2>
      <ul role="list">
        <li><a class="link-wave" href={`mailto:${site.contact.email}`}>{site.contact.email}</a></li>
        <li>{site.contact.location}</li>
      </ul>
    </div>
  </div>

  <div class="wrap footer__base">
    <p>© {year} {site.fullName}.</p>
    <p class="footer__colophon">
      Built with Astro · Content in Markdown · Deployed on Netlify
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    background: var(--abyss);
    padding-top: clamp(2.5rem, 5vw, 4rem);
    margin-top: 2rem;
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
    gap: 2.5rem 2rem;
    padding-bottom: 3rem;
  }
  .footer__tag {
    color: var(--mist);
    font-size: var(--step--1);
    max-width: 34ch;
    margin-top: 1.2rem;
    line-height: 1.6;
  }
  .footer__social {
    display: flex;
    gap: 1.4rem;
    margin-top: 1.4rem;
  }
  .footer__head {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mist);
    margin-bottom: 1rem;
    font-weight: 400;
  }
  .footer__col ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    color: var(--mist);
    font-size: var(--step--1);
  }
  .footer__col a {
    transition: color 0.25s;
  }
  .footer__col a:hover {
    color: var(--foam);
  }
  .footer__base {
    border-top: 1px solid var(--line);
    padding-block: 1.6rem 2.4rem;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.6rem;
    color: var(--mist);
    font-size: 0.78rem;
    font-family: var(--font-mono);
  }
  @media (max-width: 820px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 520px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
