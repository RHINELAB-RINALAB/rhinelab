---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection } from 'astro:content';
import { formatDateShort, isUpcoming } from '../../lib/format';

const all = await getCollection('events', (e) => !e.data.draft);
const upcoming = all
  .filter((e) => isUpcoming(e.data.endDate ?? e.data.startDate))
  .sort((a, b) => a.data.startDate.valueOf() - b.data.startDate.valueOf());
const past = all
  .filter((e) => !isUpcoming(e.data.endDate ?? e.data.startDate))
  .sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf());

function dateRange(start: Date, end?: Date) {
  if (!end) return formatDateShort(start);
  return `${formatDateShort(start)} – ${formatDateShort(end)}`;
}
---

<BaseLayout
  title="Events"
  description="Seminars, workshops, and gatherings hosted by Rhinelab."
>
  <PageHeader
    eyebrow="Events"
    title="Seminars & gatherings"
    lede="Where the lab meets the world — open seminars, reading groups, workshops, and the occasional offsite by the water."
    count={all.length}
  />

  <section class="section">
    <div class="wrap">
      {
        upcoming.length > 0 && (
          <>
            <h2 class="ev-group" data-reveal>Upcoming</h2>
            <ul class="evlist" role="list">
              {upcoming.map((e, i) => (
                <li data-reveal data-reveal-delay={`${i * 60}ms`}>
                  <a class="evrow evrow--up" href={`/events/${e.id}`}>
                    <span class="evrow__date">{dateRange(e.data.startDate, e.data.endDate)}</span>
                    <span class="evrow__kind chip">{e.data.kind}</span>
                    <span class="evrow__main">
                      <span class="evrow__title">{e.data.title}</span>
                      <span class="evrow__loc">{e.data.location}</span>
                    </span>
                    <span class="evrow__go" aria-hidden="true">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </>
        )
      }

      {
        past.length > 0 && (
          <>
            <h2 class="ev-group ev-group--past" data-reveal>Past</h2>
            <ul class="evlist" role="list">
              {past.map((e, i) => (
                <li data-reveal data-reveal-delay={`${i * 60}ms`}>
                  <a class="evrow evrow--past" href={`/events/${e.id}`}>
                    <span class="evrow__date">{dateRange(e.data.startDate, e.data.endDate)}</span>
                    <span class="evrow__kind chip">{e.data.kind}</span>
                    <span class="evrow__main">
                      <span class="evrow__title">{e.data.title}</span>
                      <span class="evrow__loc">{e.data.location}</span>
                    </span>
                    <span class="evrow__go" aria-hidden="true">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .ev-group {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mist);
    margin-bottom: 0.8rem;
  }
  .ev-group--past {
    margin-top: 3rem;
    color: var(--mist);
  }
  .evlist {
    border-top: 1px solid var(--line);
  }
  .evrow {
    display: grid;
    grid-template-columns: 190px 120px 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--line);
  }
  .evrow__date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--mist);
  }
  .evrow__kind {
    justify-self: start;
  }
  .evrow__title {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-1);
    color: var(--paper);
  }
  .evrow:hover .evrow__title {
    text-decoration: underline;
    text-decoration-color: var(--line-strong);
    text-underline-offset: 3px;
  }
  .evrow__loc {
    display: block;
    margin-top: 0.25rem;
    color: var(--mist);
    font-size: var(--step--1);
  }
  .evrow__go {
    color: var(--mist);
    font-size: 1.1rem;
  }
  @media (max-width: 820px) {
    .evrow {
      grid-template-columns: 1fr auto;
      grid-template-areas: 'date kind' 'main go';
      gap: 0.6rem 1rem;
    }
    .evrow__date { grid-area: date; align-self: center; }
    .evrow__kind { grid-area: kind; justify-self: end; }
    .evrow__main { grid-area: main; }
    .evrow__go { grid-area: go; align-self: center; }
  }
</style>
