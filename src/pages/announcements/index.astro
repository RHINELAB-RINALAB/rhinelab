---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection } from 'astro:content';
import { formatDateShort } from '../../lib/format';

const items = (await getCollection('announcements', (e) => !e.data.draft)).sort(
  (a, b) => {
    if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  },
);
---

<BaseLayout
  title="Announcements"
  description="News and announcements from Rhinelab — launches, hiring, releases, and more."
>
  <PageHeader
    eyebrow="Announcements"
    title="News from the lab"
    lede="Launches, releases, hiring, and the occasional milestone worth marking."
    count={items.length}
  />

  <section class="section">
    <div class="wrap">
      <ul class="anlist" role="list">
        {
          items.map((a, i) => (
            <li data-reveal data-reveal-delay={`${(i % 4) * 60}ms`}>
              <a class="ancard" href={`/announcements/${a.id}`}>
                <div class="ancard__top">
                  <span class="chip">{a.data.category}</span>
                  {a.data.pinned && <span class="ancard__pin">Pinned</span>}
                  <time datetime={a.data.pubDate.toISOString()}>
                    {formatDateShort(a.data.pubDate)}
                  </time>
                </div>
                <h2 class="ancard__title">{a.data.title}</h2>
                <p class="ancard__desc">{a.data.description}</p>
                <span class="ancard__more link-wave">Read more →</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .anlist {
    display: flex;
    flex-direction: column;
  }
  .ancard {
    display: block;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--line);
  }
  .anlist > li:last-child .ancard {
    border-bottom: 0;
  }
  .ancard__top {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--mist);
  }
  .ancard__pin {
    color: var(--teal);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.66rem;
  }
  .ancard__top time {
    margin-left: auto;
  }
  .ancard__title {
    font-size: var(--step-2);
    margin-top: 0.6rem;
  }
  .ancard:hover .ancard__title {
    text-decoration: underline;
    text-decoration-color: var(--line-strong);
    text-underline-offset: 3px;
  }
  .ancard__desc {
    color: var(--mist);
    margin-top: 0.5rem;
    line-height: 1.6;
    max-width: 70ch;
  }
  .ancard__more {
    display: inline-block;
    margin-top: 0.9rem;
    font-size: 0.85rem;
  }
</style>
